PORT=8120
NODE_ENV=production

# Authentik OIDC
OIDC_ISSUER=https://auth.foxteal.com/application/o/sagoconsole/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://console.sagocactus.com/auth/callback

# Session signing
JWT_SECRET=change-me-to-a-random-string

# Portainer
PORTAINER_URL=https://portainer.sagocactus.com
PORTAINER_API_KEY=

# Tugtainer
TUGTAINER_URL=http://host.docker.internal:9412
TUGTAINER_PASSWORD=

# Database
DB_PATH=/data/sagoconsole.db
